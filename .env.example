# =============================================================================
#  HostPanel — Arquivo de Configuração de Ambiente
#  Copie este arquivo para .env e preencha os valores.
#  O instalador (/install) preenche este arquivo automaticamente.
# =============================================================================

# -----------------------------------------------------------------------------
#  APLICAÇÃO
# -----------------------------------------------------------------------------
APP_NAME="HostPanel"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://seudominio.com.br
APP_TIMEZONE=America/Sao_Paulo
APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

# -----------------------------------------------------------------------------
#  BANCO DE DADOS — MySQL / MariaDB
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hostpanel
DB_USERNAME=hostpanel
DB_PASSWORD=

# -----------------------------------------------------------------------------
#  SESSÃO
#  driver: database (recomendado), file, redis, cookie
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_MAX_SIMULTANEOUS=5

# -----------------------------------------------------------------------------
#  FILAS
#  Usar 'database' (padrão) ou 'redis' (melhor desempenho em produção)
#  Para processar: php artisan queue:work --queue=email,whatsapp,default
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
#  CACHE
#  driver: database (padrão), file, redis
# -----------------------------------------------------------------------------
CACHE_STORE=file
CACHE_PREFIX=hostpanel_

# -----------------------------------------------------------------------------
#  REDIS — Opcional. Use se QUEUE_CONNECTION=redis ou CACHE_STORE=redis
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
#  E-MAIL — SMTP
#  Configure o servidor de e-mail para envio de faturas e notificações.
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.seuservidor.com.br
MAIL_PORT=587
MAIL_USERNAME=noreply@seudominio.com.br
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@seudominio.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
#  LOGS
#  level: debug (dev), info (produção recomendado), warning, error
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=info

# -----------------------------------------------------------------------------
#  SISTEMA — Parâmetros financeiros e formatação
# -----------------------------------------------------------------------------
SYSTEM_CURRENCY=BRL
SYSTEM_CURRENCY_SYMBOL=R$
SYSTEM_DATE_FORMAT=d/m/Y
SYSTEM_INVOICE_PREFIX=FAT
SYSTEM_TAX_LATE_FEE=2
SYSTEM_TAX_INTEREST_DAILY=0.033

# -----------------------------------------------------------------------------
#  INSTALADOR
#  INSTALLER_ENABLED=false após concluir a instalação.
#  O instalador define isso automaticamente ao finalizar.
# -----------------------------------------------------------------------------
INSTALLER_ENABLED=true
INSTALLED=false

# -----------------------------------------------------------------------------
#  SEGURANÇA — Credenciais sensíveis ficam no banco, NÃO aqui
# -----------------------------------------------------------------------------
#  WhatsApp (Evolution API): Admin → Configurações → Integrações
#  Gateways de pagamento:    Admin → Gateways → Configurar
#  Credenciais de servidores: Admin → Servidores → Editar
#  Todos os valores são armazenados criptografados (AES-256-CBC).

# -----------------------------------------------------------------------------
#  ARMAZENAMENTO — Disco padrão para uploads
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
#  BCRYPT — Custo do hash de senhas (12 = padrão seguro, 10 = mais rápido)
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

VITE_APP_NAME="${APP_NAME}"
